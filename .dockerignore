# Keep the docker build context lean. Only Dockerfile, docker/,
# and packages/* are consumed by the build.

.git
.github
.agents
*.log
.DS_Store

# Build outputs and dependency dirs
**/node_modules
**/dist
**/.vite
**/*.tsbuildinfo

# Source-only files we don't need in the image
README.md
LICENSE
.editorconfig
.gitattributes
